# ================================================================
# NMIMS CDOE — Root .htaccess
# Node.js app on Hostinger (Phusion Passenger / Apache)
# ================================================================

Options -Indexes -MultiViews
ServerSignature Off

# ================================================================
# PHUSION PASSENGER — Node.js Entry Point
# (Hostinger enables this automatically via the control panel,
#  but these directives ensure correct behaviour)
# ================================================================
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerStartupFile server.js
    PassengerAppType node
    PassengerResolveSymlinksInDocumentRoot on
</IfModule>

# ================================================================
# REWRITE ENGINE
# ================================================================
RewriteEngine On

# ----------------------------------------------------------------
# 1. Force HTTPS
# ----------------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# 2. Remove www (non-www canonical)
# ----------------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# 3. Block access to sensitive root-level files
# ----------------------------------------------------------------
RewriteRule ^(\.env|\.env\..+|server\.js|package\.json|package-lock\.json|blogs-data\.json|form-submissions\.json|README\.md|\.git) - [F,L]
RewriteRule ^node_modules/ - [F,L]
RewriteRule ^\.git/ - [F,L]

# ================================================================
# BLOCK SENSITIVE FILES
# ================================================================
<FilesMatch "(^\.env|server\.js|package(-lock)?\.json|blogs-data\.json|form-submissions\.json|README\.md|HOSTINGER_DEPLOYMENT\.md|\.htpasswd|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block all dot-files (hidden files)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ================================================================
# SECURITY HEADERS
# ================================================================
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Clickjacking protection — allow only same-origin iframes
    Header always set X-Frame-Options "SAMEORIGIN"

    # Legacy XSS filter (IE/Edge)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Restrict browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # HSTS — enforce HTTPS for 1 year (enable only after HTTPS is confirmed working)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Remove server fingerprinting headers
    Header unset X-Powered-By
    Header unset Server

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' 'unsafe-eval' \
            https://cdn.quilljs.com \
            https://www.googletagmanager.com \
            https://www.google-analytics.com \
            https://connect.facebook.net; \
        style-src 'self' 'unsafe-inline' \
            https://cdn.quilljs.com \
            https://fonts.googleapis.com; \
        font-src 'self' \
            https://fonts.gstatic.com \
            https://cdn.quilljs.com; \
        img-src 'self' data: blob: https:; \
        connect-src 'self' \
            https://www.google-analytics.com \
            https://analytics.google.com; \
        media-src 'self'; \
        object-src 'none'; \
        base-uri 'self'; \
        form-action 'self'; \
        frame-ancestors 'self';"
</IfModule>

# ================================================================
# GZIP / BROTLI COMPRESSION
# ================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2

    # Don't compress already-compressed formats
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|ico|zip|gz|bz2|rar)$ no-gzip dont-vary

    # Ensure proxies cache compressed and uncompressed separately
    Header append Vary Accept-Encoding
</IfModule>

# ================================================================
# BROWSER CACHING (static assets served through Express/Passenger)
# ================================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Default fallback
    ExpiresDefault "access plus 1 month"

    # HTML documents — short cache (content changes frequently)
    ExpiresByType text/html                  "access plus 1 hour"

    # CSS & JavaScript (use cache-busting filenames for long cache)
    ExpiresByType text/css                   "access plus 1 year"
    ExpiresByType application/javascript     "access plus 1 year"
    ExpiresByType text/javascript            "access plus 1 year"

    # Images
    ExpiresByType image/jpeg                 "access plus 1 year"
    ExpiresByType image/png                  "access plus 1 year"
    ExpiresByType image/gif                  "access plus 1 year"
    ExpiresByType image/webp                 "access plus 1 year"
    ExpiresByType image/svg+xml              "access plus 1 year"
    ExpiresByType image/x-icon               "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon   "access plus 1 year"

    # Fonts
    ExpiresByType font/ttf                   "access plus 1 year"
    ExpiresByType font/otf                   "access plus 1 year"
    ExpiresByType font/woff                  "access plus 1 year"
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType application/font-woff      "access plus 1 year"
    ExpiresByType application/font-woff2     "access plus 1 year"

    # Data & feeds
    ExpiresByType application/json           "access plus 1 hour"
    ExpiresByType application/xml            "access plus 1 day"
    ExpiresByType text/xml                   "access plus 1 day"
    ExpiresByType application/rss+xml        "access plus 1 day"

    # Manifests
    ExpiresByType application/manifest+json  "access plus 1 week"
    ExpiresByType text/cache-manifest        "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Versioned/hashed assets — cache forever, immutable
    <FilesMatch "\.(css|js|woff2?|ttf|otf)$">
        Header append Cache-Control "public, immutable"
    </FilesMatch>

    # Images — long public cache
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header append Cache-Control "public"
    </FilesMatch>

    # Never cache HTML or JSON API responses
    <FilesMatch "\.(html|json)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ================================================================
# CORS — allow fonts to be loaded cross-origin
# ================================================================
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ================================================================
# CUSTOM ERROR DOCUMENTS
# ================================================================
ErrorDocument 400 /index.html
ErrorDocument 401 /index.html
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
ErrorDocument 503 /index.html
